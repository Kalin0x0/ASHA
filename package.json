{
  "name": "chista",
  "private": true,
  "version": "0.1.0",
  "description": "Chista — modern container-streaming / VDI / DaaS platform (anthracite + gold).",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build --concurrency=4",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @chista/web dev",
    "dev:api": "pnpm --filter @chista/api start:dev",
    "dev:agent": "pnpm --filter @chista/agent start:dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @chista/db generate",
    "db:migrate": "pnpm --filter @chista/db migrate",
    "db:seed": "pnpm --filter @chista/db seed",
    "db:studio": "pnpm --filter @chista/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
