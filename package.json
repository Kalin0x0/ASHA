{
  "name": "asha",
  "private": true,
  "version": "0.1.0",
  "description": "Asha — modern container-streaming / VDI / DaaS platform (anthracite + gold). A Naiemi Group product.",
  "author": "Naiemi Group",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build --concurrency=4",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @asha/web dev",
    "dev:api": "pnpm --filter @asha/api start:dev",
    "dev:agent": "pnpm --filter @asha/agent start:dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @asha/db generate",
    "db:migrate": "pnpm --filter @asha/db migrate",
    "db:seed": "pnpm --filter @asha/db seed",
    "db:studio": "pnpm --filter @asha/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
