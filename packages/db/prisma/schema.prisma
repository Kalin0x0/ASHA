// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  Asha — data model (single source of truth)                              ║
// ║                                                                            ║
// ║  Multi-tenancy: every tenant-owned row carries `orgId`. Isolation is       ║
// ║  enforced at three layers: (1) a Prisma client extension that injects      ║
// ║  `where:{orgId}` from AsyncLocalStorage, (2) orgId-scoped unique indexes,   ║
// ║  (3) Postgres RLS as a backstop (added in a later migration). For that      ║
// ║  reason `orgId` is modeled as an indexed scalar rather than a formal Org    ║
// ║  back-relation on every table — the extension filters on the scalar.        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Agent enrollment tokens — admins mint named, revocable, optionally-expiring
// tokens so multiple agents/zones can enroll without sharing one static env
// secret. Only the sha256 hash is stored; the plaintext is shown once at mint.
model RegistrationToken {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  /// sha256 hex of the plaintext token.
  tokenHash   String    @unique
  zoneId      String?
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  useCount    Int       @default(0)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orgId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  DISABLED
  INVITED
  LOCKED
}

enum CredentialKind {
  PASSWORD
  WEBAUTHN
}

enum TwoFactorType {
  TOTP
  WEBAUTHN
  HARDWARE_TOKEN
}

enum AuthProviderType {
  LOCAL
  LDAP
  SAML
  OIDC
}

enum WorkspaceType {
  CONTAINER
  SERVER
  REMOTE_APP
  VM
  LINK
}

enum ImageChannel {
  CORE
  ROLLING
  CUSTOM
}

enum StreamProtocol {
  KASMVNC
  RDP
  VNC
  SSH
  WEBRTC
}

enum RegistryType {
  FIRST_PARTY
  THIRD_PARTY
}

enum SessionStatus {
  REQUESTED
  SCHEDULED
  PROVISIONING
  RUNNING
  DEGRADED
  PAUSED
  TERMINATING
  DESTROYED
  ERROR
}

enum ConnectionType {
  KASMVNC
  NEKO_WEBRTC
  GUAC_RDP
  GUAC_VNC
  GUAC_SSH
}

enum RecordingStatus {
  RECORDING
  FINALIZING
  AVAILABLE
  FAILED
}

enum AgentKind {
  DOCKER
  COMPUTE
}

enum AgentStatus {
  ONLINE
  OFFLINE
  DRAINING
  UNHEALTHY
}

enum ServerConnectionType {
  SSH
  RDP
  VNC
}

enum ServerAuthMode {
  PASSWORD
  KEY
  VMWARE_TEMPLATE
}

enum ContinuityMode {
  NONE
  TMUX
  SCREEN
}

enum ServerStatus {
  ONLINE
  OFFLINE
  PROVISIONING
  ERROR
}

enum PoolKind {
  SERVER
  AGENT
}

enum AutoscaleMode {
  SCHEDULE
  LOAD
  ACTIVE_DIRECTORY
}

enum VMProviderType {
  AWS
  AZURE
  DIGITALOCEAN
  GCP
  HARVESTER
  ORACLE
  NUTANIX
  PROXMOX
  VSPHERE
  OPENSTACK
  KUBEVIRT
}

enum DNSProviderType {
  AWS
  AZURE
  DIGITALOCEAN
  GCP
  ORACLE
}

enum ConnectionProxyType {
  GUACAMOLE
  RDP_GATEWAY
  RDP_HTTPS_GATEWAY
  NATIVE_RDP
}

enum StorageKind {
  DROPBOX
  GDRIVE
  NEXTCLOUD
  ONEDRIVE
  S3
  CUSTOM
}

enum FileMappingTarget {
  CONTAINER
  WINDOWS
}

enum PersistBackend {
  DOCKER_VOLUME
  S3
}

enum SettingScope {
  GLOBAL
  ORG
  ZONE
}

enum BrandingScope {
  GLOBAL
  ORG
  GROUP
}

enum LicenseType {
  CONCURRENT
  NAMED_USER
}

enum DeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AssignmentScope {
  USER
  GROUP
  WORKSPACE
}

// ── Bug reporting & the "fix memory" ─────────────────────────────────────────
// How a report entered the system.
enum BugSource {
  USER       // a human filed it from the portal / admin UI
  AUTOMATIC  // captured by the API exception filter or web error boundary on an unexpected crash
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  TRIAGED
  IN_PROGRESS
  RESOLVED
  CLOSED
  WONT_FIX
  DUPLICATE
}

// Who authored a fix-memory entry — an AI agent (e.g. Claude Code) or a person.
enum FixAuthorKind {
  AI
  HUMAN
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy / topology
// ─────────────────────────────────────────────────────────────────────────────

model Org {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  status    OrgStatus @default(ACTIVE)
  licenseId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model DeploymentZone {
  id           String    @id @default(cuid())
  orgId        String
  name         String
  region       String?
  isDefault    Boolean   @default(false)
  proxyBaseUrl String?
  settings     Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  agents   Agent[]
  servers  Server[]
  sessions Session[]
  workspaces Workspace[]

  @@unique([orgId, name])
  @@index([orgId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  orgId         String
  email         String
  username      String
  displayName   String?
  avatarUrl     String?
  /** SCIM externalId from the upstream IdP (e.g. Okta sub). */
  externalId    String?
  /**
   * AuthConfig.id of the identity provider that owns this federated identity.
   * Set on first SSO provisioning; once bound, a *different* IdP cannot claim
   * the account by email alone (prevents one IdP shadowing another's users).
   * Null for local (password) accounts.
   */
  federatedFrom String?
  status        UserStatus @default(ACTIVE)
  isSystemAdmin Boolean    @default(false)
  locale        String     @default("en")
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  credentials     UserCredential[]
  twoFactorMethods TwoFactorMethod[]
  refreshTokens   RefreshToken[]
  apiKeys         ApiKey[]
  settings        UserSetting[]
  groups          UserGroup[]
  assignedWorkspaces WorkspaceUser[]
  sessions        Session[]
  fileMappings    FileMapping[]

  @@unique([orgId, email])
  @@unique([orgId, username])
  @@index([orgId])
}

model UserCredential {
  id        String         @id @default(cuid())
  userId    String
  kind      CredentialKind @default(PASSWORD)
  // PASSWORD → argon2/bcrypt hash. WEBAUTHN → serialized public key credential.
  secret    String
  metadata  Json           @default("{}")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TwoFactorMethod {
  id         String        @id @default(cuid())
  userId     String
  type       TwoFactorType
  label      String?
  secret     String // TOTP secret / WebAuthn credential / token serial
  confirmed  Boolean       @default(false)
  lastUsedAt DateTime?
  createdAt  DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  family    String // rotation family id
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  orgId      String
  userId     String?
  name       String
  prefix     String    @unique
  hashedKey  String
  scopes     String[]  @default([])
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([userId])
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  valueJson Json     @default("{}")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ─────────────────────────────────────────────────────────────────────────────
// Authorization
// ─────────────────────────────────────────────────────────────────────────────

model Group {
  id                     String   @id @default(cuid())
  orgId                  String
  name                   String
  description            String?
  priority               Int      @default(100)
  // Session policy
  keepaliveExpirationSec Int? // hard cap regardless of activity
  idleDisconnectSec      Int? // disconnect after inactivity
  usageLimitSec          Int? // total usage budget
  maxConcurrentSessions  Int?
  isDefault              Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  members      UserGroup[]
  roles        GroupRole[]
  ssoMappings  SsoMapping[]
  workspaces   Workspace[]  @relation("GroupWorkspaces")

  @@unique([orgId, name])
  @@index([orgId])
}

model Role {
  id        String   @id @default(cuid())
  orgId     String? // null = built-in system role
  name      String
  description String?
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions RolePermission[]
  groups      GroupRole[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. SESSION_TERMINATE_ANY
  category    String // e.g. Sessions, Users, Infrastructure
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserGroup {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  groupId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([orgId])
  @@index([groupId])
}

/// Direct workspace→user grant. A workspace with NO group grants AND no user
/// grants is visible to EVERYONE; any grant restricts it to the listed users
/// plus the members of its assigned groups (Workspace.groups / GroupWorkspaces).
model WorkspaceUser {
  id          String   @id @default(cuid())
  orgId       String
  workspaceId String
  userId      String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([orgId])
  @@index([userId])
}

model GroupRole {
  groupId String
  roleId  String

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([groupId, roleId])
  @@index([roleId])
}

model SsoMapping {
  id          String   @id @default(cuid())
  orgId       String
  groupId     String
  authConfigId String
  // e.g. match an IdP group/attribute → assign this Asha group
  attribute   String
  value       String
  createdAt   DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([groupId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth providers / login
// ─────────────────────────────────────────────────────────────────────────────

model AuthConfig {
  id        String           @id @default(cuid())
  orgId     String
  type      AuthProviderType
  name      String
  enabled   Boolean          @default(false)
  priority  Int              @default(100)
  // Provider-specific. LDAP: url/baseDN/bindDN/domainMatch/groupLink/sync.
  // SAML: idpMetadata/spEntityId/cert. OIDC: issuer/clientId/scopes/slo.
  config    Json             @default("{}")
  secretRef String? // pointer into the sealed-secret store
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
}

model LoginConfig {
  id           String   @id @default(cuid())
  orgId        String   @unique
  noticeTitle  String?
  noticeBody   String?
  noticeRequireAck Boolean @default(false)
  assistanceText String?
  updatedAt    DateTime @updatedAt
}

model CaptchaConfig {
  id          String   @id @default(cuid())
  orgId       String   @unique
  enabled     Boolean  @default(false)
  provider    String   @default("recaptcha")
  siteKey     String?
  secretRef   String?
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Workspaces / images / registry
// ─────────────────────────────────────────────────────────────────────────────

model Workspace {
  id            String        @id @default(cuid())
  orgId         String
  name          String
  friendlyName  String
  description   String?
  type          WorkspaceType @default(CONTAINER)
  imageId       String?
  // Non-container placement: SERVER/VM/REMOTE_APP workspaces bind to a registered
  // Server; an optional preferred deployment Zone applies to every type.
  serverId      String?
  zoneId        String?
  iconUrl       String?
  categories    String[]      @default([])
  enabled       Boolean       @default(true)
  // Docker run config: env, cmd, ports, shmSize, capabilities, etc.
  dockerConfig  Json          @default("{}")
  coresLimit    Float?
  memLimitMb    Int?
  gpuCount      Int           @default(0)
  // Lifecycle limits enforced by the session reaper (null = unlimited)
  maxDurationMinutes Int?
  idleTimeoutMinutes Int?
  // Tariff weight: how fast this workspace burns a user's usage budget (1.0 =
  // real time; a GPU desktop might be 2.0). Combines with the tariff metering.
  minuteCostFactor   Float         @default(1.0)
  // Data-loss-prevention + delivery policy:
  // { clipboardUp, clipboardDown, uploads, downloads, printing, audioIn, audioOut, pwa }
  dlp           Json          @default("{}")
  // Hardware H.264 encoding policy: { count, encoder: none|nvenc|vaapi, renderDevice }
  gpu           Json          @default("{}")
  launchSchema  Json? // dynamic launch-form JSON schema
  // Optional sidecar policy attachments — resolved at session provision time.
  webFilterId        String?
  egressGatewayId    String?
  browserIsolationId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  image            Image?                  @relation(fields: [imageId], references: [id], onDelete: SetNull)
  server           Server?                 @relation(fields: [serverId], references: [id], onDelete: SetNull)
  zone             DeploymentZone?         @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  webFilter        WebFilterConfig?        @relation(fields: [webFilterId], references: [id], onDelete: SetNull)
  egressGateway    EgressGateway?          @relation(fields: [egressGatewayId], references: [id], onDelete: SetNull)
  browserIsolation BrowserIsolationConfig? @relation(fields: [browserIsolationId], references: [id], onDelete: SetNull)
  sessions    Session[]
  links       WorkspaceLink[]
  remoteApps  RemoteApp[]
  launchForms LaunchForm[]
  castings    CastingConfig[]
  stagings    SessionStaging[]
  groups        Group[]         @relation("GroupWorkspaces")
  assignedUsers WorkspaceUser[]

  @@unique([orgId, name])
  @@index([orgId])
  @@index([imageId])
  @@index([serverId])
  @@index([zoneId])
}

enum ImagePullPolicy {
  ALWAYS
  IF_NOT_PRESENT
  NEVER
}

model Image {
  id                String         @id @default(cuid())
  orgId             String? // null = global registry image
  name              String
  friendlyName      String
  dockerImage       String // repo:tag
  channel           ImageChannel   @default(CUSTOM)
  protocol          StreamProtocol @default(KASMVNC)
  architecture      String         @default("amd64")
  digest            String?
  pullPolicy        ImagePullPolicy @default(ALWAYS)
  available         Boolean        @default(true)
  // Default run config merged under Workspace.dockerConfig.
  runConfigDefaults Json           @default("{}")
  sourceRegistryEntryId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  workspaces Workspace[]
  sessions   Session[]

  @@index([orgId])
}

model Registry {
  id            String       @id @default(cuid())
  orgId         String?
  name          String
  url           String
  type          RegistryType @default(THIRD_PARTY)
  schemaVersion String?
  enabled       Boolean      @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  entries RegistryEntry[]

  @@index([orgId])
}

model RegistryEntry {
  id          String   @id @default(cuid())
  registryId  String
  name        String
  friendlyName String
  description String?
  dockerImage String
  iconUrl     String?
  categories  String[] @default([])
  raw         Json     @default("{}")
  installed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  registry Registry @relation(fields: [registryId], references: [id], onDelete: Cascade)

  @@index([registryId])
}

model WorkspaceLink {
  id          String  @id @default(cuid())
  workspaceId String
  label       String
  url         String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model RemoteApp {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  path        String
  args        String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model LaunchForm {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  schema      Json     @default("{}")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Sessions
// ─────────────────────────────────────────────────────────────────────────────

model Session {
  id                String         @id @default(cuid())
  orgId             String
  kasmId            String         @unique @default(cuid()) // opaque token used in URLs
  userId            String
  // Null for fixed-server (RDP/VNC/SSH) sessions, which connect directly to a
  // Server rather than launching a workspace container.
  workspaceId       String?
  imageId           String?
  zoneId            String
  agentId           String?
  serverId          String?
  status            SessionStatus  @default(REQUESTED)
  connectionType    ConnectionType @default(KASMVNC)
  // Denormalized for fast list rendering
  workspaceName     String?
  imageName         String?
  // Runtime
  containerId       String?
  internalHost      String?
  host              String?
  port              Int?
  traefikRouterName String?
  connectionUrl     String?
  launchValues      Json           @default("{}")
  resources         Json           @default("{}") // live { cpuPct, memMb, ... }
  streamProfile     Json           @default("{}") // live stream-control (fps/quality/bitrate/clipboard)
  recordingEnabled  Boolean        @default(false)
  persistentProfileId String?
  shareEnabled      Boolean        @default(false)
  errorMessage      String?
  terminationReason String?
  startedAt         DateTime?
  lastKeepaliveAt   DateTime?
  idleSince         DateTime?
  /// Stamped when the session is PAUSED, cleared on RESUME. Drives the paused
  /// reaper independently of updatedAt (which background stats writes churn).
  pausedAt          DateTime?
  expiresAt         DateTime?
  /// Metered usage charged against the holder's tariff budget (seconds), bumped
  /// by the metering reaper (elapsed × workspace.minuteCostFactor).
  consumedSeconds   Int             @default(0)
  destroyedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  image         Image?                @relation(fields: [imageId], references: [id], onDelete: SetNull)
  zone          DeploymentZone        @relation(fields: [zoneId], references: [id])
  agent         Agent?                @relation(fields: [agentId], references: [id], onDelete: SetNull)
  recording     Recording?
  screenshots   Screenshot[]
  controlEvents SessionControlEvent[]
  share         SessionShare?

  @@index([orgId, status])
  @@index([agentId, status])
  @@index([userId])
  @@index([workspaceId])
  @@index([zoneId])
}

model SessionControlEvent {
  id        String   @id @default(cuid())
  sessionId String
  action    String // PAUSE | RESUME | RESIZE | TERMINATE | EXEC ...
  payload   Json     @default("{}")
  actorId   String?
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Screenshot {
  id        String   @id @default(cuid())
  sessionId String
  url       String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Recording {
  id               String          @id @default(cuid())
  orgId            String
  sessionId        String          @unique
  protocol         StreamProtocol
  storageMappingId String?
  status           RecordingStatus @default(RECORDING)
  bytes            BigInt          @default(0)
  durationSec      Int             @default(0)
  startedAt        DateTime        @default(now())
  finalizedAt      DateTime?

  session   Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  artifacts RecordingArtifact[]

  @@index([orgId])
}

model RecordingArtifact {
  id          String   @id @default(cuid())
  recordingId String
  path        String
  kind        String // segment | thumbnail | metadata
  segmentNo   Int?
  bytes       BigInt   @default(0)
  createdAt   DateTime @default(now())

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  @@index([recordingId])
}

model SessionShare {
  id           String   @id @default(cuid())
  orgId        String
  sessionId    String   @unique
  shareKey     String   @unique @default(cuid())
  allowControl Boolean  @default(false)
  requireAuth  Boolean  @default(true)
  enableChat   Boolean  @default(true)
  enableAv     Boolean  @default(false)
  createdAt    DateTime @default(now())
  expiresAt    DateTime?

  session      Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participants ShareParticipant[]
  messages     ShareChatMessage[]

  @@index([orgId])
}

model ShareParticipant {
  id        String   @id @default(cuid())
  shareId   String
  userId    String?
  guestName String?
  canControl Boolean @default(false)
  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  share SessionShare @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@index([shareId])
}

model ShareChatMessage {
  id        String   @id @default(cuid())
  shareId   String
  authorId  String?
  authorName String?
  body      String
  createdAt DateTime @default(now())

  share SessionShare @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@index([shareId])
}

model SessionStaging {
  id              String   @id @default(cuid())
  orgId           String
  workspaceId     String
  zoneId          String
  desiredSessions Int      @default(0)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, zoneId])
  @@index([orgId])
}

model CastingConfig {
  id             String   @id @default(cuid())
  orgId          String
  workspaceId    String
  key            String   @unique
  allowAnonymous Boolean  @default(false)
  requireAuth    Boolean  @default(true)
  groupId        String?
