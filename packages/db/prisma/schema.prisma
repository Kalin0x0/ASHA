// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  Bug reports + the central "fix memory"                                    ║
// ║                                                                            ║
// ║  BugReport is the single intake for both human-filed bugs (source=USER)    ║
// ║  and machine-captured crashes (source=AUTOMATIC — written by the API       ║
// ║  exception filter and the web error boundary with an error code + log).    ║
// ║  A stable `fingerprint` groups recurrences and links a report to a BugFix. ║
// ║                                                                            ║
// ║  BugFix is the durable memory: when something is resolved an AI (or a      ║
// ║  human) records WHAT it was (rootCause) and HOW it was fixed (resolution). ║
// ║  Future reports with the same fingerprint surface the prior fix so the     ║
// ║  same problem never has to be diagnosed twice.                             ║
// ║                                                                            ║
// ║  orgId is nullable (like AuditLog) so unauthenticated crashes can still be ║
// ║  captured; both models are scoped at the service layer, not the Prisma     ║
// ║  tenant extension.                                                         ║
// ╚══════════════════════════════════════════════════════════════════════════╝
model BugReport {
  id            String      @id @default(cuid())
  orgId         String?
  source        BugSource   @default(USER)
  status        BugStatus   @default(OPEN)
  severity      BugSeverity @default(MEDIUM)
  title         String
  description   String      @db.Text
  /// Stable, human-quotable code derived from the fingerprint (e.g. ERR-1A2B3C4D).
  errorCode     String?
  /// Exception class / name for automatic captures (e.g. TypeError).
  errorName     String?
  stackTrace    String?     @db.Text
  /// sha256 grouping key — dedupes recurrences and matches a BugReport to a BugFix.
  fingerprint   String?
  /// Where it happened: 'web' | 'api' | 'agent'.
  component     String?
  /// Route / URL where it surfaced.
  route         String?
  httpStatus    Int?
  userAgent     String?
  appVersion    String?
  reportedById  String?
  reporterEmail String?
  metadata      Json        @default("{}")
  /// Recurrence counter — incremented instead of inserting a duplicate row.
  occurrences   Int         @default(1)
  fixId         String?
  firstSeenAt   DateTime    @default(now())
  lastSeenAt    DateTime    @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  fix BugFix? @relation(fields: [fixId], references: [id])

  @@index([orgId, status])
  @@index([source, status])
  @@index([fingerprint])
  @@index([errorCode])
}

model BugFix {
  id           String        @id @default(cuid())
  orgId        String?
  /// Matches BugReport.fingerprint so a recurrence finds this fix automatically.
  fingerprint  String?
  /// Short name of the problem this fix addresses.
  title        String
  /// What it actually was — the diagnosis.
  rootCause    String        @db.Text
  /// How it was fixed — the remediation.
  resolution   String        @db.Text
  /// Optional: how to keep it from recurring.
  prevention   String?       @db.Text
  filesTouched String[]      @default([])
  commitRef    String?
  authoredBy   FixAuthorKind @default(AI)
  /// Display name of the author (e.g. "Claude Code" or a person's name).
  authorName   String?
  tags         String[]      @default([])
  /// How many later reports this fix has matched — a recurrence signal.
  reusedCount  Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  reports BugReport[]

  @@index([orgId])
  @@index([fingerprint])
}

// ── Maintenance / Automation scheduler ───────────────────────────────────────
// Admin-configurable, recurring housekeeping the platform runs on a schedule:
// reaping dead/abandoned sessions, pruning long-dead agent rows, and (via the
// agent's Docker socket) restarting the agent fleet or the RDP/VNC/SSH bridge
// and reclaiming dangling image layers. The built-in reapers still run on their
// own fixed intervals; these rows add operator control (custom cadence, manual
// "run now", run history) and the restart/prune actions the reapers don't do.
// `orgId` scopes ownership/RBAC; the effects are host-wide (single co-located
// Docker host), matching the existing system-wide reaper model.
model MaintenanceTask {
  id              String                @id @default(cuid())
  orgId           String?
  name            String
  type            MaintenanceTaskType
  enabled         Boolean               @default(true)
  scheduleKind    ScheduleKind          @default(INTERVAL)
  /// INTERVAL mode: run every N minutes (>= 1).
  intervalMinutes Int?
  /// DAILY/WEEKLY mode: minutes since local midnight (0–1439) → the HH:MM to run at.
  atMinuteOfDay   Int?
  /// WEEKLY mode: day of week, 0=Sunday … 6=Saturday.
  weekday         Int?
  /// Task-specific options (e.g. which services to restart).
  params          Json                  @default("{}")
  lastRunAt       DateTime?
  lastStatus      MaintenanceRunStatus?
  /// Short human summary of the last run (e.g. "Reaped 12 session(s)").
  lastSummary     String?               @db.Text
  lastError       String?               @db.Text
  /// Best-effort next fire time, stamped when the job is (re)scheduled.
  nextRunAt       DateTime?
  runCount        Int                   @default(0)
  createdById     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  runs MaintenanceRun[]

  @@index([orgId, enabled])
  @@index([type])
}

model MaintenanceRun {
  id          String               @id @default(cuid())
  taskId      String
  orgId       String?
  status      MaintenanceRunStatus @default(RUNNING)
  trigger     MaintenanceTrigger   @default(SCHEDULE)
  startedAt   DateTime             @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  /// Human summary of what happened.
  summary     String?              @db.Text
  /// Count of items affected (sessions reaped, agents restarted, MB reclaimed…).
  affected    Int?
  error       String?              @db.Text
  /// User who triggered a MANUAL run (null for scheduled runs).
  actorUserId String?

  task MaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, startedAt])
  @@index([orgId])
}

enum MaintenanceTaskType {
  /// Force-finalize stuck-TERMINATING + expired + idle sessions ("clean dead live sessions").
  REAP_DEAD_SESSIONS
  /// Terminate sessions whose viewer went silent past the global idle ceiling.
  REAP_ABANDONED_SESSIONS
  /// Deregister agent rows that have been OFFLINE far longer than any restart.
  PRUNE_DEAD_AGENTS
  /// Restart the agent process(es) — the container's restart policy revives them.
  RESTART_AGENTS
  /// Restart the RDP/VNC/SSH bridge (connection-proxy + guacd) — the "terminal server".
  RESTART_CONNECTION_PROXY
  /// Reclaim dangling Docker image layers on the agent host (disk hygiene).
  PRUNE_AGENT_IMAGES
}

enum ScheduleKind {
  /// Every N minutes (intervalMinutes).
  INTERVAL
  /// Once a day at atMinuteOfDay (server-local HH:MM).
  DAILY
  /// Once a week on `weekday` at atMinuteOfDay.
  WEEKLY
}

enum MaintenanceRunStatus {
  RUNNING
  OK
  FAILED
  SKIPPED
}

enum MaintenanceTrigger {
  SCHEDULE
  MANUAL
}
