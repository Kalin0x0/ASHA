  BUG
  FEEDBACK
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  FIXED
  WONTFIX
}

/// User bug reports + feedback, and the shared "memory" admins/agents use to
/// triage them: a `status` plus a `notes` collaboration thread. `screenshot` is
/// an optional data URL captured with a bug report.
model Feedback {
