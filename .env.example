# ─────────────────────────────────────────────────────────────────────────────
# Chista — environment template. Copy to `.env` and adjust. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Branding / deployment ────────────────────────────────────────────────────
CHISTA_PRODUCT_NAME=Chista
CHISTA_BASE_DOMAIN=chista.local
CHISTA_PUBLIC_URL=https://chista.local
# Public base URL the BROWSER uses to reach a running workspace stream. Overrides
# CHISTA_PUBLIC_URL for session connection URLs (a per-zone proxyBaseUrl still
# wins). Point this at the reverse proxy reachable by end users. If it (or the
# zone URL) stays on the default *.local host, browsers that can't resolve it
# will see a clear in-app error instead of a DNS failure.
# WORKSPACE_PUBLIC_BASE_URL=https://workspaces.example.com

# Seconds a launch may sit pre-RUNNING before it is failed (so a missing agent /
# slow image pull / weak link can't hang the connecting screen forever). 0 = off.
CHISTA_LAUNCH_TIMEOUT_SECONDS=300

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=chista
POSTGRES_PASSWORD=chista_dev_change_me
POSTGRES_DB=chista
# Used by Prisma (api + db package). In compose the host is `postgres`.
DATABASE_URL=postgresql://chista:chista_dev_change_me@localhost:5432/chista?schema=public

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API / Manager ────────────────────────────────────────────────────────────
API_PORT=4000
API_BASE_URL=http://localhost:4000
# Comma-separated allowed origins for CORS.
CORS_ORIGIN=http://localhost:3000,https://chista.local

# ── Auth secrets (generate strong random values for production) ───────────────
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-32++chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-32++chars
JWT_ACCESS_TTL=900            # seconds (15m)
JWT_REFRESH_TTL=2592000       # seconds (30d)
# Signs the short-lived per-session stream token validated by Traefik forward-auth.
SESSION_TOKEN_SECRET=dev-session-token-secret-change-me-32++chars
SESSION_TOKEN_TTL=120         # seconds

# ── Crypto (32-byte hex/base64 keys) ─────────────────────────────────────────
# Seals provider secrets at rest and encrypts Guacamole connection tokens.
SECRET_SEAL_KEY=0123456789abcdef0123456789abcdef
GUAC_CRYPT_SECRET=MySuperSecretKeyForParamsToken12   # exactly 32 chars for AES-256

# ── Web (Next.js, NEXT_PUBLIC_* are exposed to the browser) ───────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
# mock = run fully on MSW seed data (no backend needed) | live = call the API
NEXT_PUBLIC_API_MODE=mock
# Optional: in mock mode, embed a real KasmVNC web client in the streaming viewer.
# Point this at a running container, e.g.
#   docker run --rm -p 6901:6901 -e VNC_PW=password kasmweb/firefox:1.16.0-rolling
# Leave unset to use the branded placeholder stream surface.
# NEXT_PUBLIC_DEMO_STREAM_URL=https://localhost:6901

# ── Agent ────────────────────────────────────────────────────────────────────
CHISTA_MANAGER_URL=http://localhost:4000
CHISTA_ZONE=default
# One-time enrollment token the agent trades for a scoped API key on first boot.
CHISTA_AGENT_ENROLLMENT_TOKEN=dev-enrollment-token-change-me
# Docker connection. On Linux/macOS: /var/run/docker.sock. On Windows: //./pipe/docker_engine
DOCKER_SOCKET=/var/run/docker.sock
# Docker network ephemeral session containers join (so Traefik can reach them).
CHISTA_SESSION_NETWORK=chista-sessions
# Public hostname Traefik routes sessions under.
CHISTA_TRAEFIK_DOMAIN=chista.local

# ── Traefik / TLS ────────────────────────────────────────────────────────────
ACME_EMAIL=admin@chista.local
